{
  "schemaVersion": "tutti.app.manifest.v1",
  "appId": "design-review",
  "version": "0.1.0",
  "name": "设计评审",
  "description": "检查流程、界面和体验问题，辅助发现设计风险。",
  "icon": {
    "type": "asset",
    "src": "icon.svg"
  },
  "runtime": {
    "bootstrap": "bootstrap.sh",
    "healthcheckPath": "/healthz"
  },
  "cli": {
    "manifest": "tutti.cli.json"
  },
  "window": {
    "minimizeBehavior": "keep-mounted",
    "minWidth": 860,
    "minHeight": 560
  },
  "authors": [
    {
      "name": "2042217959",
      "avatarUrl": "https://github.com/2042217959.png",
      "url": "https://github.com/2042217959"
    }
  ],
  "source": {
    "type": "github",
    "url": "https://github.com/tutti-os/design-review"
  },
  "tags": ["design", "review", "critique", "workspace", "ai"],
  "localizationInfo": {
    "defaultLocale": "zh-CN",
    "additionalLocales": [
      {
        "locale": "en",
        "file": "locales/en/manifest.json"
      }
    ]
  }
}
